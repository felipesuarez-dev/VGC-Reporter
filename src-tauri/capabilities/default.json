{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for VGC-Reporter main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-minimize",
    "core:window:allow-close",
    "core:window:allow-toggle-maximize",
    "core:window:allow-start-dragging",
    "core:app:default",
    "core:path:default",
    "core:event:default",
    "opener:default",
    "store:default",
    "dialog:allow-save",
    "updater:default",
    "process:default"
  ]
}
